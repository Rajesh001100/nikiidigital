{
  "name": "nikiidigital-course-registration",
  "private": true,
  "workspaces": [
    "web",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"npm:dev --workspace server\" \"npm:dev --workspace web\"",
    "build": "npm -w server run build && npm -w web run build",
    "start": "npm -w server run start",
    "lint": "npm -w web run lint && npm -w server run lint"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}

